import java.util.ArrayList;
import java.util.Scanner;

public class AttendanceTracker {

    public static void main(String[] args) {

        ArrayList<String> presentStudents = new ArrayList<>();
        Scanner sc = new Scanner(System.in);

        int choice;

        do {
            System.out.println("\n--- Attendance Tracker ---");
            System.out.println("1. Add Present Student");
            System.out.println("2. View Attendance");
            System.out.println("3. Exit");

            System.out.print("Enter your choice: ");
            choice = sc.nextInt();
            sc.nextLine();

            switch(choice) {

                case 1:
                    System.out.print("Enter student name: ");
                    String name = sc.nextLine();
                    presentStudents.add(name);
                    System.out.println("Attendance added!");
                    break;

                case 2:
                    System.out.println("\nStudents Present Today:");
                    for(String student : presentStudents) {
                        System.out.println(student);
                    }
                    break;

                case 3:
                    System.out.println("Exiting program...");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }

        } while(choice != 3);

        sc.close();
    }
}
